{
  "description": "Nepali fillers, backchannels, discourse markers, interjections, and particles for TTS system",
  "notes": {
    "usage": "These are sounds/words Nepali speakers use in natural conversation for acknowledgment, hesitation, agreement, surprise, etc.",
    "particles": "Nepali particles (निपात/nipaat) carry little standalone meaning but significantly affect sentence tone and emphasis",
    "formality": "Some items have formal vs colloquial variants; marked where applicable",
    "prosody": "Many of these can be lengthened for emphasis (e.g., ओहोहोहो for stronger surprise)"
  },
  "backchannels_and_acknowledgment": [
    {
      "word": "हजुर",
      "romanization": "hajur",
      "function": "acknowledgment_respectful",
      "description": "Respectful 'yes' or acknowledgment; used with elders/superiors; also used as a polite backchannel to show listening"
    },
    {
      "word": "हो",
      "romanization": "ho",
      "function": "agreement",
      "description": "Direct 'yes'; most common affirmative response"
    },
    {
      "word": "हो हो",
      "romanization": "ho ho",
      "function": "emphatic_agreement",
      "description": "Emphatic agreement; repeated for stronger affirmation"
    },
    {
      "word": "अँ",
      "romanization": "a~",
      "function": "acknowledgment_casual",
      "description": "Casual 'yeah'; nasalized sound showing affirmation or that one is listening"
    },
    {
      "word": "ह",
      "romanization": "ha",
      "function": "acknowledgment_minimal",
      "description": "Minimal backchannel; soft acknowledgment while listening"
    },
    {
      "word": "हुन्छ",
      "romanization": "hunchha",
      "function": "agreement_acceptance",
      "description": "'Okay' / 'will do' / 'that works'; signals acceptance or consent"
    },
    {
      "word": "ठीक छ",
      "romanization": "thik chha",
      "function": "agreement_acceptance",
      "description": "'It's okay' / 'that's fine'; signals understanding or acceptance"
    },
    {
      "word": "ठीकै छ",
      "romanization": "thikai chha",
      "function": "agreement_reassurance",
      "description": "'It's totally fine' / 'no problem'; reassuring variant"
    },
    {
      "word": "लाग्छ",
      "romanization": "lagchha",
      "function": "tentative_agreement",
      "description": "'It seems so' / 'I think so'; hedged agreement"
    },
    {
      "word": "त्यसो त",
      "romanization": "tyaso ta",
      "function": "concession",
      "description": "'That's true' / 'in that case'; conceding a point"
    }
  ],
  "hesitation_and_fillers": [
