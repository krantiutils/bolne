    },
    {
      "word": "अँ",
      "romanization": "a~",
      "function": "hesitation_thinking",
      "description": "Nasalized hesitation; also used as thinking filler (context-dependent: can be acknowledgment or hesitation)"
    },
    {
      "word": "उम्",
      "romanization": "um",
      "function": "hesitation",
      "description": "Thinking filler, equivalent to English 'um'"
    },
