  "discourse_particles": [
    {
      "word": "त",
      "romanization": "ta",
      "function": "emphasis_topic",
      "description": "Emphasizes or asserts; marks topics; equivalent to 'indeed' or 'as for'"
    },
    {
      "word": "नि",
      "romanization": "ni",
      "function": "emphasis_attention",
      "description": "Emphasizes answers/questions; draws attention to the marked element"
    },
    {
      "word": "नै",
      "romanization": "nai",
      "function": "emphasis_strong",
      "description": "Strong emphasis; augments the notion ('exactly', 'the very', 'itself')"
    },
    {
      "word": "पो",
      "romanization": "po",
      "function": "surprise_contrast",
      "description": "Indicates surprise or contrast with expectations ('actually', 'on the contrary')"
    },
    {
      "word": "रे",
      "romanization": "re",
      "function": "reported_speech",
      "description": "Indicates hearsay/reported speech ('they say', 'apparently'); also indicates unfamiliarity"
    },
    {
      "word": "चाहिँ",
      "romanization": "chahi~",
      "function": "focus_specification",
      "description": "Focuses or gives emphasis to a specific subject ('especially', 'as for', 'in particular')"
    },
    {
      "word": "कि",
      "romanization": "ki",
      "function": "doubt_question",
      "description": "Expresses doubt or uncertainty in questions; also 'or' in alternative questions"
    },
    {
      "word": "क्यारे",
      "romanization": "kyare",
      "function": "uncertainty",
      "description": "Denotes uncertainty ('probably', 'I guess', 'maybe')"
    },
    {
      "word": "न",
      "romanization": "na",
      "function": "insistence_softening",
      "description": "Shows insistence or softens imperatives; equivalent to 'please' or tag question"
    },
    {
      "word": "ल",
      "romanization": "la",
      "function": "agreement_request",
      "description": "At start: agreement ('okay, let's...'); at end: request/gentle command"
    },
    {
      "word": "है",
      "romanization": "hai",
      "function": "confirmation_seeking",
      "description": "Seeks confirmation; tag question equivalent ('okay?', 'right?', 'you know?')"
    }
  ],
