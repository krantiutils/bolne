{
  "description": "Nepali ordinal number reference for TTS text normalization (converting '1st', '2nd', etc. to spoken Nepali ordinal forms)",
  "notes": {
    "irregular_forms": "The first four ordinals (1st-4th) are fully irregular and must be memorized as special cases",
    "suffix_pattern": "Most ordinals from 5 onward are formed by adding -औं (-aũ) to the cardinal number word, but several have stem changes",
    "stem_changes": "Some numbers change their stem before the -औं suffix: e.g., नौ → नवौं (9th), छ → छैटौं (6th)",
    "alternate_forms": "4th can also appear as चौथौं (chauthauṃ) in some dialects; पहिलो is sometimes written as प्रथम in formal contexts",
    "usage": "Ordinals are used with -औं suffix for ranking/ordering; पहिलो/दोस्रो/तेस्रो are the most common in everyday speech"
  },
  "suffix_rules": {
    "default_suffix": "औं",
    "default_suffix_romanization": "-aũ",
    "description": "The general pattern is: cardinal number word + औं. Irregular forms exist for 1st through 4th and a few others where the stem changes.",
    "examples": [
      "पाँच + औं → पाँचौं (5th)",
      "सात + औं → सातौं (7th)",
      "दश + औं → दशौं (10th)"
    ]
  },
